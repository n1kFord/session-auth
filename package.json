{
  "name": "session-auth",
  "version": "1.0.0",
  "description": "🔐 Production-ready authentication boilerplate with Express.js, sessions, CSRF protection, and Redis",
  "main": "src/index.js",
  "scripts": {
    "start": "node ./src/index.js",
    "dev": "nodemon ./src/index.js",
    "test": "NODE_ENV=test jest --runInBand --forceExit --detectOpenHandles",
    "test:ci": "NODE_ENV=test jest --runInBand --forceExit --detectOpenHandles --ci --coverage"
  },
  "keywords": [
    "express",
    "authentication",
    "session",
    "csrf",
    "redis",
    "mongodb",
    "security",
    "boilerplate"
  ],
  "author": "n1kFord",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n1kFord/session-auth.git"
  },
  "bugs": {
    "url": "https://github.com/n1kFord/session-auth/issues"
  },
  "homepage": "https://github.com/n1kFord/session-auth#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "mongoose": "^9.6.1",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "jest": "^30.4.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
